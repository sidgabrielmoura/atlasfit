generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GlobalRole {
  SUPERADMIN
  TRAINER
  STUDENT
  USER
}

enum WorkspaceRole {
  OWNER
  TRAINER
  ASSISTANT
  STUDENT
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String?           @unique
  password         String?
  setupToken       String?           @unique
  emailVerified    DateTime?
  image            String?
  role             GlobalRole        @default(USER)
  onboarded        Boolean           @default(false)
  twoFactorEnabled Boolean?
  isTestAccount    Boolean           @default(false)
  objective        String?
  gender           String?
  birthDate        DateTime?
  experienceLevel  String?
  medicalConditions String?           @db.Text
  weight            Float?
  height            Float?
  accounts         Account[]
  sessions         Session[]
  workspaces       WorkspaceMember[]
  auditLogs        AuditLog[]
  createdExercises Exercise[]        @relation("CreatedExercises")
  workouts         Workout[]         @relation("CreatedWorkouts")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Personal Trainer profile fields
  bio        String?
  specialty  String?
  whatsapp   String?
  instagram  String?
  linkedin   String?
  city       String?
  experience String?
  cref       String?
  imageKey   String?

  subscription           Subscription?
  freeTrial              FreeTrial?
  transactions           Transaction[]
  subscriptionActivities SubscriptionActivity[]
  adjustmentRequests     ExerciseAdjustmentRequest[]
  adjustmentMessages     AdjustmentMessage[]
  studentWorkouts        Workout[]                   @relation("StudentWorkouts")
  progressHistory        StudentProgress[]
  progressPhotos         StudentProgressPhoto[]
  physicalEvaluations    PhysicalEvaluation[]
  studentFiles           StudentFile[]
  workoutLogs            WorkoutLog[]
  studentTasks           TrainerTask[]               @relation("StudentTasks")
  dailyFeedbacks         DailyFeedback[]
  campaignViews          CampaignView[]
  leads                  Lead[]
  notificationDevices    NotificationDevice[]
  notifications          Notification[]
  notificationPreference NotificationPreference?
}

model Workspace {
  id              String             @id @default(cuid())
  name            String
  slug            String             @unique
  ownerId         String
  isActive        Boolean            @default(true)
  slogan          String?
  logoUrl         String?
  primaryColor    String?            @default("#ea580c")
  watermarkUrl    String?
  workoutCoverUrl String?
  logoKey         String?
  watermarkKey    String?
  workoutCoverKey String?
  members         WorkspaceMember[]
  plans           WorkspacePlan[]
  payments        WorkspacePayment[]
  pendingStudents PendingStudent[]
  trainerTasks    TrainerTask[]
  workouts        Workout[]
  progressHistory StudentProgress[]
  progressPhotos  StudentProgressPhoto[]
  dailyFeedbacks  DailyFeedback[]
  leads           Lead[]
  tags            Tag[]
  customFields    CustomFieldDefinition[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(STUDENT)
  isActive    Boolean       @default(true)
  plan        String        @default("Mensal")
  streak      Int           @default(0)
  bestStreak  Int           @default(0)
  progress    Int           @default(0)
  lastActive  DateTime?     @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([userId, workspaceId])
}

model Plan {
  id                     String                 @id @default(cuid())
  name                   String
  price                  Float
  interval               String                 @default("month") // "month" or "year"
  features               String?
  maxWorkspaces          Int                    @default(1)
  maxStudents            Int?                   // Limite de alunos (null = ilimitado)
  subscriptions          Subscription[]
  subscriptionActivities SubscriptionActivity[]
}

model Subscription {
  id                String    @id @default(cuid())
  userId            String    @unique
  planId            String
  status            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              Plan      @relation(fields: [planId], references: [id])
  startDate         DateTime  @default(now())
  endDate           DateTime?
  isPreSubscription Boolean   @default(false)
}

model FreeTrial {
  id        String   @id @default(cuid())
  userId    String   @unique
  startDate DateTime @default(now())
  endDate   DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id            String   @id @default(cuid())
  userId        String
  amount        Float
  status        String // "APPROVED", "PENDING", "FAILED", "REFUNDED"
  paymentMethod String? // "CREDIT_CARD", "PIX", "BOLETO"
  description   String?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  discountPercent Int
  maxUses         Int?
  usedCount       Int       @default(0)
  expirationDate  DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  ip        String?
  severity  String   @default("info")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model MuscleGroup {
  id            String     @id @default(cuid())
  name          String     @unique
  exercises     Exercise[] @relation("SingleGroup")
  exercisesMany Exercise[] @relation("MultiGroups")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Exercise {
  id            String  @id @default(cuid())
  name          String
  creatorId     String?
  videoUrl      String?
  usage         Int     @default(0)
  isOfficial    Boolean @default(false)
  status        String  @default("PENDING") // PENDING, APPROVED, REJECTED
  muscleGroupId String

  muscleGroup        MuscleGroup                 @relation("SingleGroup", fields: [muscleGroupId], references: [id], onDelete: Cascade)
  muscleGroups       MuscleGroup[]               @relation("MultiGroups")
  creator            User?                       @relation("CreatedExercises", fields: [creatorId], references: [id], onDelete: SetNull)
  workoutExercises   WorkoutExercise[]
  adjustmentRequests ExerciseAdjustmentRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Workout {
  id         String            @id @default(cuid())
  name       String
  goal       String // "Hipertrofia", "Emagrecimento", "Força", "Resistência", etc. (pra que serve)
  difficulty String // "Iniciante", "Intermediário", "Avançado"
  duration   String // "60 min", "45 min" (tempo de treino)
  creatorId   String?
  creator     User?             @relation("CreatedWorkouts", fields: [creatorId], references: [id], onDelete: SetNull)
  workspaceId String?
  workspace   Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  exercises      WorkoutExercise[]
  exerciseGroups WorkoutExerciseGroup[]

  // Aluno a quem o treino pertence (se for exclusivo/atribuído individualmente)
  studentId            String?
  student              User?             @relation("StudentWorkouts", fields: [studentId], references: [id], onDelete: Cascade)
  dayOfWeek            Int?              // 0=Dom, 1=Seg, 2=Ter, 3=Qua, 4=Qui, 5=Sex, 6=Sáb
  muscleGroupLabel     String?      // Ex: "Peito e Tríceps", "Membros Inferiores"
  restBetweenExercises String?      @default("2 min")
  isActive             Boolean      @default(true)
  workoutLogs          WorkoutLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkoutExercise {
  id         String @id @default(cuid())
  workoutId  String
  exerciseId String
  sets       Int // séries
  reps       String // repetições
  rest       String // descanso
  load         String? // carga (peso) prescrita
  order        Int                  @default(0) // ordem
  methodType   MethodType           @default(NONE)
  methodConfig Json?
  groupId      String?
  group        WorkoutExerciseGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  type        String   @default("string") // string, boolean, number
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SubscriptionActivity {
  id        String   @id @default(cuid())
  userId    String
  planId    String
  type      String // "NEW_SUBSCRIPTION", "RENEWAL", "CANCELLATION", "UPGRADE"
  amount    Float
  status    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      Plan     @relation(fields: [planId], references: [id])
  createdAt DateTime @default(now())
}

model SystemIntegration {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  url       String?
  icon      String   @default("Zap") // Lucide icon name
  status    String   @default("Operational")
  latency   String?
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExerciseAdjustmentRequest {
  id          String   @id @default(cuid())
  exerciseId  String
  description String
  requesterId String
  status      String   @default("PENDING") // PENDING, RESOLVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  exercise  Exercise            @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  requester User                @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  messages  AdjustmentMessage[]

  @@index([exerciseId])
  @@index([requesterId])
}

model AdjustmentMessage {
  id              String   @id @default(cuid())
  requestId       String
  senderId        String
  message         String
  isReadByTrainer Boolean  @default(true)
  isReadByAdmin   Boolean  @default(true)
  createdAt       DateTime @default(now())

  request ExerciseAdjustmentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender  User                      @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([senderId])
}

model WorkspacePlan {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  price       Float
  interval    String   @default("mensal") // "mensal", "trimestral", "semestral", "anual"
  link        String? // link base de checkout / pagamento
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model WorkspacePayment {
  id          String   @id @default(cuid())
  workspaceId String
  studentName String
  planName    String
  amount      Float
  status      String // "pago", "pendente", "atrasado"
  method      String // "PIX", "BOLETO", "CREDIT_CARD"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model PendingStudent {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String?
  whatsapp    String?
  plan        String    @default("Mensal")
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

model TrainerTask {
  id             String   @id @default(cuid())
  workspaceId    String
  title          String
  time           String // "10:00" etc.
  type           String // "avaliação", "financeiro", "check-in", "lembrete"
  completed      Boolean  @default(false)
  scheduledDate  String?  // "yyyy-MM-dd" armazenado como string local (sem conversão UTC)
  studentId      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  student   User?     @relation("StudentTasks", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([scheduledDate])
  @@index([studentId])
}

model StudentProgress {
  id              String   @id @default(cuid())
  studentId       String
  workspaceId     String
  date            DateTime @default(now())
  
  // Composição Corporal
  weight          Float?   // Peso em kg
  height          Float?   // Altura em cm
  bodyFat         Float?   // Percentual de Gordura %
  muscleMass      Float?   // Percentual de Massa Magra %
  
  // Medidas de Circunferência (em cm)
  chest           Float?   // Peito
  waist           Float?   // Cintura
  abdomen         Float?   // Abdômen
  hips            Float?   // Quadril
  rightArm        Float?   // Braço Direito
  leftArm         Float?   // Braço Esquerdo
  rightForearm    Float?   // Antebraço Direito
  leftForearm     Float?   // Antebraço Esquerdo
  rightThigh      Float?   // Coxa Direita
  leftThigh       Float?   // Coxa Esquerda
  rightCalf       Float?   // Panturrilha Direita
  leftCalf        Float?   // Panturrilha Esquerda
  
  notes           String?  // Observações gerais
  
  // Relações
  student         User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([studentId])
  @@index([workspaceId])
}

model StudentProgressPhoto {
  id              String   @id @default(cuid())
  studentId       String
  workspaceId     String
  photoUrl        String
  objectKey       String?
  mimeType        String?
  size            Int?
  uploadedBy      String?
  date            DateTime @default(now())
  
  trainerLiked    Boolean  @default(false)
  comment         String?  @db.Text
  
  student         User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([studentId])
  @@index([workspaceId])
}

model PhysicalEvaluation {
  id          String   @id @default(cuid())
  studentId   String
  workspaceId String
  date        DateTime @default(now())
  type        String   // "Dobra Cutânea (Pollock 7 Dobras)", "Bioimpedância", etc.
  weight      Float
  height      Float
  bodyFat     Float?
  muscleMass  Float?
  dobras      Json?    // Armazena as dobras (triceps, peitoral, abdominal, coxa, suprailiaca, etc.)
  
  // Novas seções estruturadas da Avaliação Física
  anamnese        Json?    // Respostas do questionário de anamnese
  circunferencias Json?    // Medidas das circunferências corporais
  postural        Json?    // Avaliação postural (fotos, desvios e laudo)
  dorMobilidade   Json?    // Mapa de dor e limitações de mobilidade
  testesFisicos   Json?    // Resultados dos testes de flexibilidade, cardio e força

  notes       String?  @db.Text

  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([studentId])
  @@index([workspaceId])
}

model StudentFile {
  id          String   @id @default(cuid())
  studentId   String
  workspaceId String
  name        String   // Descrição visual / Nome amigável do arquivo
  category    String   // "exames" | "dieta_treino" | "outros"
  type        String   // "file" | "link"
  fileName    String?  // Nome físico do arquivo se for upload
  fileSize    String?  // Tamanho formatado (ex: "2.4 MB") ou "Link"
  url         String   // URL do arquivo em nuvem ou URL externa
  objectKey   String?
  mimeType    String?
  size        Int?
  uploadedBy  String?
  notes       String?  @db.Text

  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([studentId])
  @@index([workspaceId])
}

model WorkoutLog {
  id          String   @id @default(cuid())
  studentId   String
  workoutId   String
  workspaceId String
  completedAt DateTime @default(now())
  feedback    String?  // Ex: "Treino top", "Fadiguei no supino"
  effortScore Int?     // 1 (Muito Fácil) a 5 (Muito Difícil)
  loads       Json?    // Cargas logadas por exercício/série
  reps        Json?    // Repetições reais por exercício/série

  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  workout     Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([studentId])
  @@index([workoutId])
  @@index([workspaceId])
}

model DailyFeedback {
  id          String    @id @default(cuid())
  studentId   String
  workspaceId String
  energy      Int
  fatigue     Int
  humor       Int
  date        DateTime  @default(now())

  student     User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([studentId])
  @@index([workspaceId])
}

enum MethodType {
  NONE
  DROPSET
  REST_PAUSE
  BISET
  TRISET
  CIRCUIT
}

model WorkoutExerciseGroup {
  id         String            @id @default(cuid())
  workoutId  String
  type       MethodType
  config     Json?
  
  workout    Workout           @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercises  WorkoutExercise[]

  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

enum CampaignType {
  PROMOTION
  ANNOUNCEMENT
  UPDATE
}

enum CampaignTarget {
  PERSONAL
  STUDENT
  ALL
}

model Campaign {
  id           String         @id @default(cuid())
  title        String
  description  String         @db.Text
  imageUrl     String?
  imageKey     String?
  type         CampaignType
  targetRole   CampaignTarget
  startDate    DateTime
  endDate      DateTime
  buttonText   String?
  buttonLink   String?
  showOnlyOnce Boolean        @default(false)
  isActive     Boolean        @default(true)
  priority     Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  views        CampaignView[]

  @@index([isActive, targetRole])
  @@index([startDate, endDate])
}

model CampaignView {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  viewedAt   DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
}

model Lead {
  id             String             @id @default(cuid())
  workspaceId    String
  ownerId        String
  name           String
  phone          String?
  whatsapp       String?
  email          String?
  instagram      String?
  goal           String?
  source         String?
  notes          String?            @db.Text
  potentialValue Float?
  status         String
  lostReason     String?
  lostReasonDetails String?         @db.Text
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner          User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  activities     LeadActivity[]
  tasks          LeadTask[]
  tags           Tag[]
  customValues   CustomFieldValue[]
  files          LeadFile[]

  @@index([workspaceId])
  @@index([ownerId])
  @@index([status])
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model LeadTask {
  id        String   @id @default(cuid())
  leadId    String
  title     String
  status    String   @default("PENDING")
  dueDate   DateTime?
  time      String?  @default("09:00")
  priority  String   @default("MEDIA")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model Tag {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leads       Lead[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model CustomFieldDefinition {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  type        String   @default("text")
  options     String?
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  values      CustomFieldValue[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model CustomFieldValue {
  id                  String                @id @default(cuid())
  leadId              String
  fieldDefinitionId   String
  value               String

  lead                Lead                  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  definition          CustomFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)

  @@unique([leadId, fieldDefinitionId])
  @@index([leadId])
  @@index([fieldDefinitionId])
}

model LeadFile {
  id          String   @id @default(cuid())
  leadId      String
  fileName    String
  fileSize    String
  url         String
  objectKey   String?
  mimeType    String?
  size        Int?
  uploadedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model NotificationDevice {
  id            String   @id @default(cuid())
  userId        String
  firebaseToken String   @unique
  platform      String?
  browser       String?
  status        String   @default("ACTIVE")
  lastSeen      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  type        String
  category    String
  title       String
  description String
  image       String?
  icon        String?
  priority    String    @default("NORMAL")
  payload     Json?
  deepLink    String?
  source      String?
  isRead      Boolean   @default(false)
  delivered   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  readAt      DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  settings  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


